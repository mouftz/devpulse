# Docker Compose reads this file from the project root when you run services.
# Copy to .env for Docker-based development, and keep real values out of Git.

GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Optional Gitea support.
GITEA_BASE_URL=https://your-gitea.example.com
GITEA_TOKEN=your_gitea_access_token

# Background worker settings.
SYNC_INTERVAL_SECONDS=86400
RUN_ON_START=true
BIGQUERY_PROJECT=devpulse-local
